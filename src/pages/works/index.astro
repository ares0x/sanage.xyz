---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = '作品集 · Sanage 产品矩阵';
const description = 'Sanage 旗下互动作品与子站全览：Quiz 测评室（谍战人格测试 · 武林外传角色匹配）、Brain 训练室（专注力 · 反应速度训练）、CalmFlow 桌面执行系统、Liuyao 六爻排盘室。把有意思的问题，做成能玩的东西。';
const works = await getCollection('works');

// 所有在线的排前面
const sortedWorks = [...works].sort((a, b) => {
  if (a.data.status === 'online' && b.data.status !== 'online') return -1;
  if (a.data.status !== 'online' && b.data.status === 'online') return 1;
  return 0;
});

const themeAccent: Record<string, { icon: string; bg: string; ring: string }> = {
  amber:  { icon: '🕵️', bg: '#fdf7ee', ring: '#f0d9b5' },
  indigo: { icon: '🧠', bg: '#f0f0ff', ring: '#c7c7f0' },
  orange: { icon: '🔥', bg: '#fff4ee', ring: '#ffd0b5' },
  emerald:{ icon: '✨', bg: '#effdf4', ring: '#a7f3c5' },
  rose:   { icon: '💡', bg: '#fff0f3', ring: '#ffc5d0' },
};
---

<BaseLayout title={title} description={description} ogImage="/images/og/works.png" schemaType="website">

  <section class="max-w-3xl mx-auto px-6 py-14 md:py-20">

    {/* 页头 */}
    <div class="mb-12">
      <p class="text-[11px] tracking-[0.2em] text-[#b87333] uppercase mb-3 font-medium animate-fade-in-up">
        作品
      </p>
      <h1 class="text-[32px] md:text-[40px] font-bold text-[#1a1a18] leading-tight animate-fade-in-up delay-100">
        在做的东西
      </h1>
      <p class="text-[14px] text-[#9a9a94] mt-2 animate-fade-in-up delay-200">
        把有意思的问题做成能玩的产品
      </p>
    </div>

    {/* 作品列表 */}
    <div class="flex flex-col gap-4">
      {sortedWorks.map((work, i) => {
        const accent = themeAccent[work.data.theme] ?? themeAccent.amber;
        const isOnline = work.data.status === 'online';
        return (
          <div
            class="reveal group bg-white border border-[#ebe8e4] rounded-2xl overflow-hidden"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="flex flex-col sm:flex-row sm:items-stretch">

              {/* 左侧图标区 */}
              <div
                class="sm:w-[88px] sm:flex-shrink-0 flex items-center justify-center p-5 sm:p-0"
                style={`background-color: ${accent.bg};`}
              >
                <div
                  class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl border"
                  style={`background: white; border-color: ${accent.ring};`}
                >
                  {work.data.emoji}
                </div>
              </div>

              {/* 右侧内容区 */}
              <div class="flex-1 min-w-0 p-5 sm:p-6 border-t sm:border-t-0 sm:border-l border-[#ebe8e4]">

                {/* 顶部：标题 + 状态 */}
                <div class="flex items-center gap-2.5 mb-2">
                  <h2 class="text-[17px] font-semibold text-[#1a1a18]">{work.data.title}</h2>
                  <span class={`text-[10px] font-medium px-2 py-[2px] rounded-full ${
                    work.data.statusLabel === '开源'
                      ? 'bg-violet-50 text-violet-700'
                      : isOnline
                        ? 'bg-emerald-50 text-emerald-700'
                        : 'bg-gray-100 text-gray-500'
                  }`}>
                    {work.data.statusLabel === '开源' ? '开源自部署' : work.data.statusLabel}
                  </span>
                </div>

                {/* 标签 */}
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {work.data.tags.map((tag: string) => (
                    <span class="text-[11px] px-2 py-[2px] rounded-md bg-[#f5f3f0] text-[#8a8a84]">
                      {tag}
                    </span>
                  ))}
                </div>

                {/* 描述 */}
                <p class="text-[13px] text-[#6b6b65] leading-[1.75] mb-4">
                  {work.data.description}
                </p>

                {/* 链接 */}
                <div class="flex items-center gap-4">
                  {work.data.links.map((link: { label: string; url: string }) => (
                    isOnline ? (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-[13px] font-medium text-[#b87333] hover:text-[#9a5e22] transition-colors"
                        onclick={`trackEvent('click_work', {work_name: '${work.data.slug}'})`}
                      >
                        {link.label} <span class="text-[11px]">↗</span>
                      </a>
                    ) : (
                      <span class="text-[13px] text-[#c5c5be] cursor-not-allowed">
                        {link.label}（即将上线）
                      </span>
                    )
                  ))}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    {/* 底部提示 */}
    <div class="mt-10 reveal">
      <p class="text-[13px] text-[#b5b5ae]">
        更多作品正在筹备中，不一定是测评，但一定好玩。
      </p>
    </div>

  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
