---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = '作品集 · 互动人格测试与 AI 执行效率工具矩阵 | Sanage';
const description = 'Sanage 旗下互动作品与子站全览。包括：Quiz 测评室（谍战人格测试、武林外传匹配）、CalmFlow 桌面 AI 任务拆解系统与 Bu 占卜室（周易与多元占卜平台）。';

const works = await getCollection('works');

// Sort works based on specific business weights
const order = ['lab', 'calmflow', 'quiz', 'bu'];
const sortedWorks = [...works].sort((a, b) => {
  return order.indexOf(a.data.slug) - order.indexOf(b.data.slug);
});

// Format to match the design system list specifications
const items = sortedWorks.map((w, idx) => {
  let role = 'Web · 数字化产品';
  let year = '2025 –';
  if (w.data.slug === 'lab') {
    role = 'AI 阵地 · 咨询展示';
    year = '2026';
  } else if (w.data.slug === 'calmflow') {
    role = '桌面端 · 心流工具';
    year = '2026';
  } else if (w.data.slug === 'quiz') {
    role = 'Web · 人格测评';
    year = '2024 –';
  } else if (w.data.slug === 'bu') {
    role = 'Web · 数字化占卜';
    year = '2025 –';
  }

  return {
    n: String(idx + 1).padStart(2, '0'),
    title: w.data.title,
    year,
    role,
    href: w.data.links[0]?.url || '#',
    desc: w.data.description,
  };
}).concat([
  {
    n: String(works.length + 1).padStart(2, '0'),
    title: 'Sanage Blog',
    year: '2023 –',
    role: '写作 · 长期杠杆',
    href: '/blog/',
    desc: '记录产品思考、独立开发与影视文化随笔，时常更新。'
  }
]);
---

<BaseLayout title={title} description={description} ogImage="/images/og/works.png" schemaType="website">

  {/* Page Header */}
  <section class="container-edit pt-16 md:pt-24 pb-12 border-b border-[var(--rule)]">
    <p class="eyebrow">WORKS · 作品集</p>
    <h1 class="mt-4 font-display text-6xl md:text-8xl leading-[0.95] text-[var(--ink)] max-w-4xl">
      所有作品都是 <span class="italic text-[var(--ember)]">未完成</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--ink-soft)] leading-relaxed">
      一份持续生长的清单。每一个产品都是一次自我实验，不为完美而存在，为生长而存在。
    </p>
  </section>

  {/* Works List */}
  <section class="container-edit py-4">
    <ul class="list-none pl-0">
      {items.map((w) => (
        <li class="group rule-top">
          <a
            href={w.href}
            target={w.href.startsWith("http") ? "_blank" : undefined}
            rel={w.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="grid grid-cols-12 gap-4 py-8 md:py-10 items-baseline hover:bg-[var(--paper-deep)] transition-colors px-2 -mx-2 no-underline"
          >
            <span class="col-span-2 md:col-span-1 font-mono text-sm text-[var(--ink-soft)]">{w.n}</span>
            <div class="col-span-10 md:col-span-5">
              <h2 class="font-display text-4xl md:text-6xl text-[var(--ink)] group-hover:text-[var(--ember)] transition-colors m-0">
                {w.title}
              </h2>
            </div>
            <div class="col-span-6 md:col-span-3">
              <p class="eyebrow m-0">{w.role}</p>
              <p class="mt-2 text-sm text-[var(--ink-soft)] m-0">{w.desc}</p>
            </div>
            <div class="col-span-6 md:col-span-3 md:text-right">
              <p class="font-mono text-sm text-[var(--ink-soft)] m-0">{w.year}</p>
              <p class="mt-2 font-mono text-xs text-[var(--ink)] group-hover:text-[var(--ember)] inline-flex items-center gap-2 m-0">
                访问 <span class="transition-transform group-hover:translate-x-1">→</span>
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>
