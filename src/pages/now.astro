---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '我正在做的事 · 独立开发者 Jace 的行动与状态快照 | Sanage';
const description = 'Jace (三阿哥又长高了吗) 正在关注和构建的最新动态快照。包含 Build in Public 自媒体内容创作进展、CalmFlow 桌面端迭代细节以及 Quiz 测评大改版等真实日常状态。';
const keywords = '三阿哥,Jace,now page,正在做什么,CalmFlow,独立开发,个人品牌,状态,深圳';

const LOG = [
  { date: "2026.06.24", tag: "SHIPPED", title: "Liuyao 升级与域名迁移", body: "将占卜排盘服务迁移至 bu.sanage.xyz，完成主站链接与 SEO 数据对齐。" },
  { date: "2026.06.14", tag: "BUILDING", title: "CalmFlow 桌面版内测", body: "针对核心内测用户发布第一版安装包，重点优化无摩擦任务拆解流程与系统托盘常驻机制。" },
  { date: "2026.06.05", tag: "RESEARCH", title: "AI 测评系统开发", body: "研究如何结合大语言模型按特定影视人设自动生产高维场景下的趣味测评题目。" },
  { date: "2026.05.28", tag: "READING", title: "重读《纳瓦尔宝典》", body: "再次梳理「将自己产品化」的行动主线，思考以代码与内容作为无边际成本杠杆的更佳组合。" },
  { date: "2026.05.18", tag: "WRITING", title: "撰写博客随笔", body: "完成《一人公司的核心是一人，不是公司》的系统化思考与排版写作，并正式在主站博客上线。" },
  { date: "2026.05.02", tag: "SHIPPED", title: "Quiz 增加肤色诊断", body: "上线了基于经典色彩学的趣味肤色诊断室，优化了移动端滑动调色卡片的响应性能。" },
];
---

<BaseLayout title={title} description={description} keywords={keywords} ogImage="/images/og/about.png" schemaType="person">

  {/* Page Header */}
  <section class="container-edit pt-16 md:pt-24 pb-12 border-b border-[var(--rule)]">
    <p class="eyebrow">NOW · 现在</p>
    <h1 class="mt-4 font-display text-6xl md:text-8xl leading-[0.95] text-[var(--ink)] max-w-4xl">
      最近在做 <span class="italic text-[var(--ember)]">什么。</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--ink-soft)] leading-relaxed">
      公开构建是我的创作逻辑。这里是没有滤镜的迭代节奏——交付、研究、阅读、写作。
    </p>
  </section>

  {/* Content Layout */}
  <section class="container-edit py-16 grid md:grid-cols-12 gap-12">
    {/* Left Column: Timeline */}
    <div class="md:col-span-8">
      <p class="eyebrow mb-8">BUILD LOG · 构建日志</p>
      <ol class="relative border-l border-[var(--rule)] pl-8 space-y-12 list-none">
        {LOG.map((e) => (
          <li class="relative">
            <span class="absolute -left-[37px] top-2 grid place-items-center h-4 w-4 rounded-full bg-[var(--paper)] border-2 border-[var(--ember)]">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--ember)]"></span>
            </span>
            <div class="flex flex-wrap items-center gap-3">
              <time class="font-mono text-xs text-[var(--ink-soft)]">{e.date}</time>
              <span class="chip">{e.tag}</span>
            </div>
            <h3 class="mt-3 font-display text-3xl md:text-4xl text-[var(--ink)]">{e.title}</h3>
            <p class="mt-3 text-[var(--ink-soft)] max-w-2xl leading-relaxed">{e.body}</p>
          </li>
        ))}
      </ol>
    </div>

    {/* Right Column: Status & Thoughts */}
    <aside class="md:col-span-4 space-y-8">
      <div class="border border-[var(--rule)] bg-[var(--card)] p-6">
        <p class="eyebrow">📍 当前状态</p>
        <p class="mt-3 text-sm text-[var(--ink-soft)] leading-relaxed">
          坐标深圳，全职独立开发与自媒体运营，设备主力为 MacBook Pro，每天处于高密度的构建节奏中。
        </p>
      </div>

      <div class="border border-[var(--rule)] bg-[var(--card)] p-6">
        <p class="eyebrow">📖 正在学习</p>
        <ul class="mt-3 space-y-3 text-sm text-[var(--ink-soft)] leading-relaxed list-none pl-0">
          <li>— 认知行为疗法（CBT无摩擦阻力设计）与行为设计学。</li>
          <li>— 端侧 LLM 本地离线部署与延迟调优。</li>
        </ul>
      </div>

      <div class="border border-[var(--rule)] bg-[var(--card)] p-6">
        <p class="eyebrow">💭 最近在思考</p>
        <ul class="mt-3 space-y-3 text-sm text-[var(--ink-soft)] leading-relaxed list-none pl-0">
          <li>— 产品化自己（Productize Yourself）的底层架构与长期杠杆的组合方式。</li>
          <li>— 如何通过轻量级工具矩阵构建独立创作者的流量底座。</li>
        </ul>
      </div>
    </aside>
  </section>

</BaseLayout>
