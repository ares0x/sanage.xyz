---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blogs');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = `${post.data.title} · 博客`;
const description = post.data.description;
const keywords = post.data.tags ? post.data.tags.join(',') : '';

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
};
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  ogImage="/images/og/works.png"
  ogType="article"
  schemaType="article"
  schemaData={{
    name: post.data.title,
    description: post.data.description,
    pubDatetime: post.data.pubDatetime,
    url: `https://sanage.xyz/blog/${post.slug}/`
  }}
>
  <article class="container-edit max-w-3xl pt-16 md:pt-24 pb-20 md:pb-28">
    {/* 返回链接 */}
    <div class="mb-8">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-xs text-[var(--ink-soft)] hover:text-[var(--ember)] transition-colors no-underline">
        ← 返回列表
      </a>
    </div>

    {/* 文章头部 */}
    <header class="mb-10 border-b border-[var(--rule)] pb-8">
      <time datetime={post.data.pubDatetime.toISOString()} class="text-xs text-[var(--ink-soft)] block mb-3 font-mono uppercase">
        {formatDate(post.data.pubDatetime)}
      </time>
      <h1 class="font-display text-4xl md:text-6xl text-[var(--ink)] leading-[0.95] mb-4">
        {post.data.title}
      </h1>
      <p class="text-lg text-[var(--ink-soft)] leading-relaxed m-0">
        {post.data.description}
      </p>
      
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="chip">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--ember)]"></span> {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {/* 文章主体 */}
    <div class="prose">
      <Content />
    </div>

    {/* 页尾快速导航 */}
    <footer class="mt-14 pt-8 border-t border-[var(--rule)] flex justify-between items-center text-xs font-mono text-[var(--ink-soft)]">
      <span>三阿哥又长高了吗 · 博客</span>
      <a href="/blog/" class="text-[var(--ink)] hover:text-[var(--ember)] no-underline">
        返回列表 →
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .prose {
    font-size: 16px;
    line-height: 1.75;
    color: var(--ink-soft);
  }
  .prose :global(p) {
    margin-top: 1.5em;
    margin-bottom: 1.5em;
  }
  .prose :global(h1), .prose :global(h2), .prose :global(h3), .prose :global(h4) {
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 700;
    margin-top: 1.8em;
    margin-bottom: 0.8em;
    letter-spacing: -0.01em;
  }
  .prose :global(h1) { font-size: 2.25em; }
  .prose :global(h2) { font-size: 1.75em; border-bottom: 1px solid var(--rule); padding-bottom: 0.3em; }
  .prose :global(h3) { font-size: 1.4em; }
  .prose :global(h4) { font-size: 1.15em; }
  
  .prose :global(ul), .prose :global(ol) {
    margin-top: 1em;
    margin-bottom: 1em;
    padding-left: 1.5em;
  }
  .prose :global(ul) { list-style-type: disc; }
  .prose :global(ol) { list-style-type: decimal; }
  .prose :global(li) {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }
  
  .prose :global(blockquote) {
    margin: 1.5em 0;
    padding: 0.75rem 1rem;
    border-left: 4px solid var(--ember);
    color: var(--ink-soft);
    font-style: italic;
    background-color: var(--paper-deep);
    border-radius: 0;
  }
  
  .prose :global(pre) {
    margin: 1.5em 0;
    padding: 1.25rem;
    background-color: var(--paper-deep);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.85em;
    line-height: 1.6;
  }
  .prose :global(code) {
    background-color: var(--paper-deep);
    color: var(--ember);
    padding: 0.2em 0.4em;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  .prose :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }
  
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--rule);
    border-radius: 0;
    margin: 2em auto;
    display: block;
  }
  
  .prose :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--ember);
    text-underline-offset: 4px;
    font-weight: 500;
  }
  .prose :global(a:hover) {
    color: var(--ember);
  }
  
  .prose :global(hr) {
    margin: 2em 0;
    border: 0;
    border-top: 1px solid var(--rule);
  }
</style>
