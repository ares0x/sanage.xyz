---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = '随笔与思考 · 记录关于产品设计、AI与一人公司的思考博客 | Sanage';
const description = 'Jace (三阿哥又长高了吗) 的个人随笔与思考博客。这里长期记录关于独立开发者的商业探索、AI 工作流与个人成长的深度复盘和经验分享。';
const keywords = '博客,随笔,独立开发,个人思考,产品设计,AI工具,三阿哥';

const posts = await getCollection('blogs');
// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime());

const [feat, ...rest] = sortedPosts;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
};
---

<BaseLayout title={title} description={description} keywords={keywords} ogImage="/images/og/works.png" schemaType="website">

  {/* Page Header */}
  <section class="container-edit pt-16 md:pt-24 pb-12 border-b border-[var(--rule)]">
    <p class="eyebrow">BLOG · 博客</p>
    <h1 class="mt-4 font-display text-6xl md:text-8xl leading-[0.95] text-[var(--ink)] max-w-4xl">
      慢慢 <span class="italic text-[var(--ember)]">想清楚。</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--ink-soft)] leading-relaxed">
      写作是把感觉升级成思考、把思考升级成结构的过程。这里是我所有结构化思考的入口。
    </p>
  </section>

  {/* Blog Content Section */}
  <section class="container-edit py-16 space-y-16">
    {feat && (
      <a href={`/blog/${feat.slug}/`} class="group block rule-top pt-10 no-underline" onclick={`trackEvent('click_blog_post', {slug: '${feat.slug}', featured: true})`}>
        <div class="grid md:grid-cols-12 gap-8">
          <div class="md:col-span-3">
            <p class="eyebrow">FEATURED {feat.data.tags && feat.data.tags[0] ? `· ${feat.data.tags[0]}` : ''}</p>
            <p class="mt-3 font-mono text-sm text-[var(--ink-soft)]">{formatDate(feat.data.pubDatetime)}</p>
          </div>
          <div class="md:col-span-9">
            <h2 class="font-display text-5xl md:text-7xl text-[var(--ink)] group-hover:text-[var(--ember)] leading-[1.02] transition-colors m-0">
              {feat.data.title}
            </h2>
            <p class="mt-6 max-w-2xl text-lg text-[var(--ink-soft)] m-0 leading-relaxed">{feat.data.description}</p>
            <p class="mt-6 font-mono text-xs text-[var(--ember)] m-0">阅读全文 →</p>
          </div>
        </div>
      </a>
    )}

    <ul class="list-none pl-0">
      {rest.map((p) => (
        <li class="rule-top">
          <a href={`/blog/${p.slug}/`} class="group grid md:grid-cols-12 gap-6 py-8 items-baseline hover:bg-[var(--paper-deep)] transition-colors px-2 -mx-2 no-underline" onclick={`trackEvent('click_blog_post', {slug: '${p.slug}'})`}>
            <div class="md:col-span-3">
              <p class="eyebrow m-0">{p.data.tags && p.data.tags[0] ? p.data.tags[0] : '随笔'}</p>
              <p class="mt-1 font-mono text-sm text-[var(--ink-soft)] m-0">{formatDate(p.data.pubDatetime)}</p>
            </div>
            <div class="md:col-span-7">
              <h3 class="font-display text-3xl md:text-4xl text-[var(--ink)] group-hover:text-[var(--ember)] transition-colors m-0">
                {p.data.title}
              </h3>
              <p class="mt-2 text-[var(--ink-soft)] m-0 text-sm">{p.data.description}</p>
            </div>
            <div class="md:col-span-2 md:text-right">
              <span class="font-mono text-[var(--ink-soft)] group-hover:text-[var(--ember)] group-hover:translate-x-1 inline-block transition-transform">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>
