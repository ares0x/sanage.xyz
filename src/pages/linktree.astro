---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Sanage 全平台链接 · 三阿哥又长高了吗';
const description = '在小红书、抖音、即刻、GitHub 找到三阿哥（Sanage / Jace），或者直接体验人格测试、脑力训练、六爻排盘等互动产品。';
---

<BaseLayout title={title} description={description} ogImage="/images/og/linktree.png" schemaType="person">
  <meta slot="head" name="robots" content="noindex, follow" />
  <section class="max-w-md mx-auto px-4 py-12 md:py-20">
    <div class="text-center mb-10">
      <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center text-3xl">
        🎭
      </div>
      <h1 class="text-2xl font-bold mb-1">Sanage</h1>
      <p class="text-gray-500 text-sm">创作者 / 开发者 / 影视文化爱好者</p>
    </div>

    <div class="flex flex-col gap-4">
      <a href="https://github.com/ares0x" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-4 p-4 bg-white rounded-xl border border-gray-100 hover:shadow-md transition-shadow"
         onclick="trackEvent('click_social', {platform: 'github'})">
        <div class="w-10 h-10 rounded-full bg-gray-900 flex items-center justify-center text-white text-lg">🐙</div>
        <div>
          <div class="font-medium">GitHub</div>
          <div class="text-sm text-gray-400">@ares0x</div>
        </div>
      </a>

      <a href="https://quiz.sanage.xyz/" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-4 p-4 bg-white rounded-xl border border-gray-100 hover:shadow-md transition-shadow"
         onclick="trackEvent('click_social', {platform: 'quiz'})">
        <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-lg">🕵️</div>
        <div>
          <div class="font-medium">Quiz 测评室 · 人格测试</div>
          <div class="text-sm text-gray-400">quiz.sanage.xyz</div>
        </div>
      </a>

      <a href="https://brain.sanage.xyz/" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-4 p-4 bg-white rounded-xl border border-gray-100 hover:shadow-md transition-shadow"
         onclick="trackEvent('click_social', {platform: 'brain'})">
        <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 text-lg">🧠</div>
        <div>
          <div class="font-medium">Brain 训练室 · 脑力游戏</div>
          <div class="text-sm text-gray-400">brain.sanage.xyz</div>
        </div>
      </a>
    </div>

    <div class="mt-12 text-center">
      <a href="/" class="text-sm text-gray-400 hover:text-gray-600">sanage.xyz</a>
    </div>
  </section>
</BaseLayout>
