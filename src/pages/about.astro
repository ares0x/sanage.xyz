---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '关于 Jace · 三阿哥又长高了吗 · 独立开发者与创作者简介';
const description = 'Jace，一名开发者与独立创作者。致力于“把想法变成可以被体验的产品”。核心项目包含自媒体Build in Public内容创作、Quiz测评平台、CalmFlow桌面端执行系统与数字化占卜平台。';
const keywords = '三阿哥又长高了吗,Jace,sanage,独立开发者,创作者,开发者,个人品牌,个人成长,独立开发,CalmFlow,Quiz';
---

<BaseLayout title={title} description={description} keywords={keywords} ogImage="/images/og/about.png" schemaType="person">

  {/* Page Header */}
  <section class="container-edit pt-16 md:pt-24 pb-12 border-b border-[var(--rule)]">
    <p class="eyebrow">ABOUT · 关于</p>
    <h1 class="mt-4 font-display text-6xl md:text-8xl leading-[0.95] text-[var(--ink)] max-w-4xl">
      把自己 <span class="italic text-[var(--ember)]">产品化。</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--ink-soft)] leading-relaxed">
      独立开发者 · 写作者 · 构建认知与效率工具。相信知识杠杆与长期主义。
    </p>
  </section>

  {/* Content Columns */}
  <section class="container-edit py-16 grid md:grid-cols-12 gap-12">
    <div class="md:col-span-7 space-y-6 text-[var(--ink)] leading-relaxed text-lg">
      <p>
        我是三阿哥。过去几年，我用 <em class="text-[var(--ember)] not-italic">Quiz 测评室</em> 让 29,000+
        人完成过一次关于自己的小型实验；用 <em class="text-[var(--ember)] not-italic">CalmFlow</em>
        尝试让「启动」这件事不再有摩擦；用 <em class="text-[var(--ember)] not-italic">Bu 占卜室</em>
        把传统占卜搬进当代界面。
      </p>
      <p>
        最近在 <em class="text-[var(--ember)] not-italic">Sanage AI Lab</em> 把这一切重新组织成一个「AI 阵地」——
        一边沉淀作品，一边把非共识的观察整理成可被复用的建议。
      </p>
      <p>
        写作是我对外公开的最稳定杠杆。所有产品背后的思考，最终都会回到{" "}
        <a class="underline decoration-[var(--ember)] underline-offset-4 text-[var(--ink)] font-medium" href="/blog/">博客</a>。
      </p>
    </div>

    <aside class="md:col-span-5 space-y-8">
      <div class="border border-[var(--rule)] bg-[var(--card)] p-6">
        <p class="eyebrow">信条 · CREDO</p>
        <ul class="mt-4 space-y-3 font-display text-2xl text-[var(--ink)] leading-snug list-none pl-0">
          <li>— 把自己产品化。</li>
          <li>— 用知识杠杆，而非时间杠杆。</li>
          <li>— 公开构建，被时间复利。</li>
        </ul>
      </div>
      <div class="border border-[var(--rule)] bg-[var(--card)] p-6">
        <p class="eyebrow">联络 · ELSEWHERE</p>
        <ul class="mt-4 space-y-2 font-mono text-sm list-none pl-0">
          <li>X / Twitter — <a class="text-[var(--ember)] no-underline" href="https://okjike.com/u/493AC967-4EAA-4F10-A618-25150146733E" target="_blank" rel="noopener noreferrer">@三阿哥又长高了吗</a></li>
          <li>Email — <a class="text-[var(--ember)] no-underline" href="mailto:hi@sanage.xyz">hi@sanage.xyz</a></li>
          <li>RSS — <a class="text-[var(--ember)] no-underline" href="/sitemap-index.xml">/sitemap-index.xml</a></li>
        </ul>
      </div>
    </aside>
  </section>

</BaseLayout>
