---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '三阿哥又长高了吗 · 探索认知、AI与个体成长';
const description = '自我认知实验室——谍战人格测试、武林外传角色匹配、脑力训练、CalmFlow 桌面执行系统、六爻排盘。把有意思的问题做成能玩的东西，29000+ 人已测试。';

const ecosystems = [
  // ── 第一行：核心互动产品 ──
  {
    icon: '🕵️',
    iconBg: '#faf0e0',
    name: 'Quiz 测评室',
    desc: '谍战人格测试 · 武林外传角色匹配 · 肤色诊断',
    domain: 'quiz.sanage.xyz',
    url: 'https://quiz.sanage.xyz/',
    cta: '开始测试',
    slug: 'quiz',
    featured: false,
  },
  {
    icon: '🧠',
    iconBg: '#f0f0ff',
    name: 'Brain 训练室',
    desc: '专注力 · 反应速度 · 注意力 · 30 秒见分晓',
    domain: 'brain.sanage.xyz',
    url: 'https://brain.sanage.xyz/',
    cta: '开始训练',
    slug: 'brain',
    featured: false,
  },
  {
    icon: '🌊',
    iconBg: '#edf6ff',
    name: 'CalmFlow',
    desc: 'AI 任务拆解 · 降低认知负荷 · 心流启动桌面端',
    domain: 'calmflow.sanage.xyz',
    url: 'https://calmflow.sanage.xyz/',
    cta: '立即体验',
    slug: 'calmflow',
    featured: true,   // 主推产品，绿色高亮
  },
  // ── 第二行：其他内容 ──
  {
    icon: '☯️',
    iconBg: '#fdf3eb',
    name: 'Liuyao 排盘室',
    desc: '传统六爻排盘 · 现代易学数理 · 问道解惑',
    domain: 'liuyao.sanage.xyz',
    url: 'https://liuyao.sanage.xyz/',
    cta: '去求一卦',
    slug: 'liuyao',
    featured: false,
  },
  {
    icon: '✍️',
    iconBg: '#f0f7f0',
    name: '博客',
    desc: '产品思考 · 独立开发 · 影视文化随笔',
    domain: 'sanage.xyz/blog',
    url: '/blog/',
    cta: '去看看',
    slug: 'blog',
    featured: false,
  },
];
---

<BaseLayout title={title} description={description} ogImage="/images/og/home.png" schemaType="website">

  {/* ── Hero ── */}
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-20 md:pt-28 md:pb-28 min-h-[calc(100vh-3.5rem)] flex flex-col justify-center">

    {/* 装饰背景圆 */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <div style="
        position: absolute;
        top: -120px; right: -80px;
        width: 480px; height: 480px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(184,115,51,0.06) 0%, transparent 70%);
      "></div>
    </div>

    {/* 小标签 */}
    <p class="animate-fade-in-up text-[11px] tracking-[0.22em] text-[#b87333] uppercase mb-7 font-medium">
      三阿哥的个人品牌主港
    </p>

    {/* 主标题 */}
    <h1 class="animate-fade-in-up delay-100 text-[48px] md:text-[68px] font-bold text-[#1a1a18] leading-[1.15] mb-7 tracking-tight">
      三阿哥又长高了吗
    </h1>

    {/* 副文案 */}
    <p class="animate-fade-in-up delay-200 text-[16px] md:text-[18px] text-[#6b6b65] leading-[1.75] mb-10 max-w-[480px]">
      探索认知、AI与个体成长。<br />
      把有趣的问题做成有趣的产品。
    </p>

    {/* CTA 区 */}
    <div class="animate-fade-in-up delay-300 flex flex-wrap items-center gap-3.5">
      <a
        href="#ecosystem"
        class="cta-primary"
        id="hero-cta-works"
        onclick="trackEvent('click_hero_cta', {destination: 'works'})"
      >
        查看作品 <span class="arrow">→</span>
      </a>
      <a
        href="/blog/"
        class="btn-secondary"
        id="hero-cta-blog"
        onclick="trackEvent('click_hero_cta', {destination: 'blog'})"
      >
        阅读博客 →
      </a>
      <a
        href="/now/"
        class="btn-secondary"
        id="hero-cta-now"
        onclick="trackEvent('click_hero_cta', {destination: 'now'})"
      >
        关注动态 →
      </a>
    </div>

    {/* 向下滚动提示 */}
    <div class="animate-fade-in delay-400 mt-14 hidden md:flex items-center gap-2 text-[11px] text-[#c5c5be] tracking-wider">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
      SANAGE LAB
    </div>
  </section>

  {/* ── 生态索引 ── */}
  <section id="ecosystem" class="max-w-4xl mx-auto px-6 pb-20 md:pb-28">
    <div class="border-t border-[#ebe8e4] pt-14">

      <div class="reveal mb-10">
        <p class="text-[11px] tracking-[0.18em] text-[#b87333] uppercase mb-3 font-semibold">
          SANAGE LAB
        </p>
        <h2 class="text-2xl md:text-3xl font-bold text-[#1a1a18] mb-3">产品矩阵</h2>
        <p class="text-[14px] text-[#6b6b65] max-w-xl leading-relaxed">
          正在构建帮助人们认识自己、提升认知和采取行动的工具。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {ecosystems.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`eco-card reveal group flex flex-col rounded-2xl p-5 no-underline ${
              item.featured
                ? 'bg-white border-2 border-[#1D9E75]'
                : 'bg-white border border-[#ebe8e4]'
            }`}
            id={`eco-card-${item.slug}`}
            onclick={`trackEvent('click_eco_card', {destination: '${item.slug}'})`}
          >
            {/* 图标 + 新标签 */}
            <div class="flex items-start justify-between mb-4">
              <div
                class="w-10 h-10 rounded-xl flex items-center justify-center text-xl flex-shrink-0"
                style={`background-color: ${item.iconBg};`}
              >
                {item.icon}
              </div>
              {item.featured && (
                <span class="text-[10px] font-medium px-2 py-[3px] rounded-full bg-[#EAF7F0] text-[#1D9E75] flex-shrink-0">
                  新
                </span>
              )}
            </div>

            {/* 名称 */}
            <div class={`text-[15px] font-semibold mb-1.5 ${item.featured ? 'text-[#0D2016]' : 'text-[#1a1a18]'}`}>
              {item.name}
            </div>

            {/* 描述 */}
            <p class="text-[12px] text-[#9a9a94] leading-[1.65] mb-4 flex-1">
              {item.desc}
            </p>

            {/* 域名 + 箭头 */}
            <div class="flex items-end justify-between gap-2 mt-auto">
              <span class="text-[11px] text-[#c5c5be] break-all leading-tight">{item.domain}</span>
              <span
                class={`text-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap flex-shrink-0 ${
                  item.featured ? 'text-[#1D9E75]' : 'text-[#b87333]'
                }`}
              >
                {item.cta} →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ── Build in Public ── */}
  <section class="max-w-4xl mx-auto px-6 pb-20 md:pb-28">
    <div class="border-t border-[#ebe8e4] pt-14">
      <div class="reveal mb-10">
        <p class="text-[11px] tracking-[0.18em] text-[#b87333] uppercase mb-3 font-semibold">
          BUILD IN PUBLIC
        </p>
        <h2 class="text-2xl md:text-3xl font-bold text-[#1a1a18] mb-3">最近在做什么</h2>
        <p class="text-[14px] text-[#6b6b65] leading-relaxed">
          公开构建（Build in Public）是我的创作逻辑，这里记录我最近的迭代步伐与日常探索。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="reveal bg-white border border-[#ebe8e4] rounded-2xl p-5 flex items-start gap-4">
          <span class="text-[#1D9E75] text-base font-bold mt-0.5">✓</span>
          <div>
            <h3 class="text-[15px] font-semibold text-[#1a1a18] mb-1">CalmFlow 桌面版内测</h3>
            <p class="text-[12px] text-[#9a9a94] leading-relaxed">桌面端内测正在开展中，着重调优语音分析触发器与心流无摩擦启动链路。</p>
          </div>
        </div>
        <div class="reveal bg-white border border-[#ebe8e4] rounded-2xl p-5 flex items-start gap-4">
          <span class="text-[#1D9E75] text-base font-bold mt-0.5">✓</span>
          <div>
            <h3 class="text-[15px] font-semibold text-[#1a1a18] mb-1">Brain 训练室迭代</h3>
            <p class="text-[12px] text-[#9a9a94] leading-relaxed">优化专注力与注意力反馈曲线算法，使测试数据表现更加契合认知心理学模型。</p>
          </div>
        </div>
        <div class="reveal bg-white border border-[#ebe8e4] rounded-2xl p-5 flex items-start gap-4">
          <span class="text-[#1D9E75] text-base font-bold mt-0.5">✓</span>
          <div>
            <h3 class="text-[15px] font-semibold text-[#1a1a18] mb-1">AI 测评系统开发</h3>
            <p class="text-[12px] text-[#9a9a94] leading-relaxed">研究通过 LLM 管道进行基于特定人设和危机场景的测评题库自动化生成流程。</p>
          </div>
        </div>
        <div class="reveal bg-white border border-[#ebe8e4] rounded-2xl p-5 flex items-start gap-4">
          <span class="text-[#1D9E75] text-base font-bold mt-0.5">✓</span>
          <div>
            <h3 class="text-[15px] font-semibold text-[#1a1a18] mb-1">阅读《纳瓦尔宝典》</h3>
            <p class="text-[12px] text-[#9a9a94] leading-relaxed">再次研读有关“将自己产品化”（Productize Yourself）及知识与技术杠杆的章节。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── AI Lab ── */}
  <section class="max-w-4xl mx-auto px-6 pb-20 md:pb-28">
    <div class="border-t border-[#ebe8e4] pt-14">
      <div class="reveal mb-10">
        <p class="text-[11px] tracking-[0.18em] text-[#b87333] uppercase mb-3 font-semibold">
          AI LAB
        </p>
        <h2 class="text-2xl md:text-3xl font-bold text-[#1a1a18] mb-3">AI 实验室</h2>
        <p class="text-[14px] text-[#6b6b65] leading-relaxed">
          未来核心增长入口：整合 AI 工作流、实验性微型产品、行业产品拆解与个人创业日志。
        </p>
      </div>

      <div class="reveal relative overflow-hidden rounded-2xl bg-gradient-to-br from-[#1a1a18] to-[#2c2c28] p-6 md:p-8 text-white group shadow-sm animate-fade-in">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
          <div class="absolute -right-16 -bottom-16 w-72 h-72 rounded-full bg-[#b87333]/15 blur-3xl group-hover:bg-[#b87333]/25 transition-all duration-500"></div>
        </div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
          <div class="max-w-xl">
            <span class="text-[10px] font-semibold tracking-wider px-2 py-0.5 rounded bg-[#b87333] text-white uppercase mb-4 inline-block">
              Coming Soon
            </span>
            <h3 class="text-lg md:text-xl font-bold mb-2 tracking-tight">ai.sanage.xyz</h3>
            <p class="text-[13px] text-[#aeaea5] leading-relaxed mb-5">
              这里将作为我的 AI 探索主港，沉淀高效 AI 工作流、前沿 AI 实验与拆解。我们将在这里见证一个用 AI 撬动一人公司的实践日志。
            </p>
            <div class="flex flex-wrap gap-2 text-[11px] text-[#c5c5be]">
              <span class="px-2.5 py-1 rounded bg-white/5 border border-white/10 hover:border-white/20 transition-colors">🤖 AI 工作流</span>
              <span class="px-2.5 py-1 rounded bg-white/5 border border-white/10 hover:border-white/20 transition-colors">🧪 AI 实验</span>
              <span class="px-2.5 py-1 rounded bg-white/5 border border-white/10 hover:border-white/20 transition-colors">🔍 产品拆解</span>
              <span class="px-2.5 py-1 rounded bg-white/5 border border-white/10 hover:border-white/20 transition-colors">📝 创业日志</span>
            </div>
          </div>
          <div class="flex-shrink-0">
            <span class="inline-flex items-center gap-1.5 text-xs text-[#b87333] font-semibold bg-white/10 border border-white/15 px-4.5 py-3 rounded-xl group-hover:bg-[#b87333] group-hover:text-white transition-all duration-300">
              规划建设中
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── 关于（极简）── */}
  <section class="max-w-4xl mx-auto px-6 pb-16">
    <div class="border-t border-[#ebe8e4] pt-10">
      <p class="reveal text-[14px] text-[#9a9a94] leading-[1.9]">
        三阿哥又长高了吗。喜欢把有趣的问题做成能玩的东西。
        <a
          href="/about/"
          class="text-[#b87333] hover:underline underline-offset-2 ml-1"
          onclick="trackEvent('click_nav', {destination: 'about'})"
        >
          关于我 →
        </a>
      </p>
    </div>
  </section>

</BaseLayout>

<script>
  // Scroll reveal for sections below the hero
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
    observer.observe(el);
  });
</script>
