---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = '三阿哥又长高了吗 · 个人品牌主港';
const description = '29,000+ 人参与的认知与效率工具集——AI 实验室、CalmFlow 心流、Quiz 测评、Bu 占卜与博客。';

type Product = {
  tag?: string;
  emoji: string;
  title: string;
  sub: string;
  desc: string;
  href: string;
  domain: string;
  cta: string;
  featured?: boolean;
  internal?: boolean;
};

const PRODUCTS: Product[] = [
  {
    tag: "新",
    emoji: "🧪",
    title: "Sanage AI Lab",
    sub: "AI 建造阵地 · 非共识观察",
    desc: "AI 时代的极简咨询与作品展示，聚焦非共识的产品视角与实验。",
    href: "https://lab.sanage.xyz",
    domain: "lab.sanage.xyz",
    cta: "去实验室",
    featured: true,
  },
  {
    emoji: "🌊",
    title: "CalmFlow",
    sub: "AI 任务拆解 · 心流启动",
    desc: "桌面端心流工具，降低认知负荷，让启动这一步不再有摩擦。",
    href: "https://calmflow.sanage.xyz",
    domain: "calmflow.sanage.xyz",
    cta: "立即体验",
  },
  {
    emoji: "🕵️",
    title: "Quiz 测评室",
    sub: "人格 · 角色 · 肤色诊断",
    desc: "谍战人格、武林外传角色匹配、肤色诊断——29,000+ 人玩过。",
    href: "https://quiz.sanage.xyz",
    domain: "quiz.sanage.xyz",
    cta: "开始测试",
  },
  {
    emoji: "🔮",
    title: "Bu 占卜室",
    sub: "数字化多元占卜",
    desc: "周易起卦与数字算卦，问道解惑，把传统装进当代界面。",
    href: "https://bu.sanage.xyz",
    domain: "bu.sanage.xyz",
    cta: "去求一卦",
  },
  {
    emoji: "✍️",
    title: "博客",
    sub: "产品 · 独立开发 · 文化",
    desc: "记录产品思考、独立开发与影视文化随笔，时常更新。",
    href: "/blog/",
    domain: "sanage.xyz/blog",
    cta: "去看看",
    internal: true,
  },
];

const LOG = [
  { date: "2026.06.24", title: "Liuyao 升级与域名迁移", body: "六爻排盘服务迁至 bu.sanage.xyz，主站链接与 SEO 数据已对齐。", tag: "SHIPPED" },
  { date: "2026.06.14", title: "CalmFlow 桌面版内测", body: "调优语音分析触发器与心流无摩擦启动链路；本周加入快捷键与系统托盘。", tag: "BUILDING" },
  { date: "2026.06.05", title: "AI 测评系统开发", body: "研究通过 LLM 管道按特定人设和危机场景生成题库的流程。", tag: "RESEARCH" },
  { date: "2026.05.28", title: "重读《纳瓦尔宝典》", body: "再读「将自己产品化」与杠杆章节，重新校准长期方向。", tag: "READING" },
] as const;

const STATS = [
  { k: "29,000+", v: "测试参与者" },
  { k: "5", v: "在跑产品线" },
  { k: "120+", v: "公开构建日志" },
  { k: "∞", v: "正在生长" },
];

const posts = await getCollection('blogs');
const sortedPosts = posts.sort((a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime());
const latestPost = sortedPosts[0];
const blogTeasers = sortedPosts.slice(0, 3);
---

<BaseLayout title={title} description={description} ogImage="/images/og/home.png" schemaType="website">

  {/* Hero Section */}
  <section class="container-edit pt-16 md:pt-24 pb-20 md:pb-28">
    <div class="grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8">
        <div class="flex items-center gap-3">
          <span class="chip">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--ember)]"></span>
            三阿哥的个人品牌主港
          </span>
          <span class="eyebrow">已有 29,000+ 人参与</span>
        </div>
        <h1 class="mt-6 font-display text-[15vw] md:text-[9.5vw] lg:text-[8rem] leading-[0.95] tracking-tight text-[var(--ink)]">
          三阿哥<br />
          <span class="italic text-[var(--ember)]">又长高了</span>吗
        </h1>
        <p class="mt-8 max-w-xl text-lg text-[var(--ink-soft)] leading-relaxed">
          一份持续生长的认知与效率工具集——
          <span class="text-[var(--ink)] font-medium">测评你的人格</span>，
          <span class="text-[var(--ink)] font-medium">训练你的大脑</span>，
          <span class="text-[var(--ink)] font-medium">管理你的状态</span>。
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href="#ecosystem"
            class="group inline-flex items-center gap-3 px-6 py-3.5 bg-[var(--ink)] text-[var(--paper)] text-sm tracking-wider uppercase font-mono hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[4px_4px_0_0_var(--ember)] transition-all no-underline"
          >
            查看作品 <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
          <a
            href="/blog/"
            class="inline-flex items-center gap-2 px-6 py-3.5 border border-[var(--ink)] text-sm tracking-wider uppercase font-mono hover:bg-[var(--ink)] hover:text-[var(--paper)] transition-colors no-underline text-[var(--ink)]"
          >
            阅读博客 →
          </a>
          <a
            href="/now/"
            class="inline-flex items-center gap-2 px-6 py-3.5 text-sm tracking-wider uppercase font-mono text-[var(--ink-soft)] hover:text-[var(--ember)] transition-colors no-underline"
          >
            关注动态 →
          </a>
        </div>
      </div>

      <aside class="md:col-span-4 border-l border-[var(--rule)] pl-6 md:pl-8 self-stretch flex flex-col justify-end">
        <p class="eyebrow">最新随笔 · LATEST ESSAY</p>
        {latestPost && (
          <a
            href={`/blog/${latestPost.slug}/`}
            class="mt-3 group block no-underline"
          >
            <h3 class="font-display text-2xl md:text-3xl leading-snug text-[var(--ink)] group-hover:text-[var(--ember)] transition-colors">
              《{latestPost.data.title}》
            </h3>
            <p class="mt-3 text-sm text-[var(--ink-soft)] line-clamp-2">
              {latestPost.data.description}
            </p>
            <p class="mt-4 font-mono text-xs text-[var(--ember)]">阅读全文 →</p>
          </a>
        )}

        <div class="mt-10 rule-top pt-6">
          <p class="eyebrow">现在 · NOW</p>
          <p class="mt-2 text-sm text-[var(--ink)]">
            CalmFlow 桌面端内测中 · AI 测评系统迭代第三周
          </p>
        </div>
      </aside>
    </div>
  </section>

  {/* Marquee Section */}
  <div class="rule-top border-b border-[var(--rule)] bg-[var(--paper-deep)] overflow-hidden">
    <div class="flex gap-12 py-4 whitespace-nowrap animate-[marquee_38s_linear_infinite] font-display text-2xl text-[var(--ink)]">
      {["SANAGE LAB", "BUILD IN PUBLIC", "PRODUCTIZE YOURSELF", "认知 · 效率 · 心流", "29,000+ TESTERS"].concat(
        ["SANAGE LAB", "BUILD IN PUBLIC", "PRODUCTIZE YOURSELF", "认知 · 效率 · 心流", "29,000+ TESTERS"],
        ["SANAGE LAB", "BUILD IN PUBLIC", "PRODUCTIZE YOURSELF", "认知 · 效率 · 心流", "29,000+ TESTERS"]
      ).map((t) => (
        <span class="flex items-center gap-12">
          {t}
          <span class="text-[var(--ember)]">✦</span>
        </span>
      ))}
    </div>
  </div>

  {/* Products Matrix */}
  <section id="ecosystem" class="container-edit pt-24 pb-12 scroll-mt-20">
    <header class="grid md:grid-cols-12 gap-6 items-end mb-10">
      <div class="md:col-span-7">
        <p class="eyebrow">产品矩阵 · ECOSYSTEM</p>
        <h2 class="mt-3 font-display text-5xl md:text-6xl text-[var(--ink)] leading-[1.02]">
          正在构建，让人 <span class="italic text-[var(--ember)]">认识自己</span>、<br />提升认知、采取行动 的工具。
        </h2>
      </div>
      <p class="md:col-span-5 text-[var(--ink-soft)] md:text-right md:pb-2">
        每一个产品都是一次对"将自己产品化"的实验。点击进入子站，或读它背后的笔记。
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-5">
      {PRODUCTS.map((p, idx) => {
        const span = p.featured
          ? "md:col-span-4 md:row-span-2 min-h-[420px]"
          : idx === 3 || idx === 4
            ? "md:col-span-3 min-h-[220px]"
            : "md:col-span-2 min-h-[220px]";
        
        return (
          <a
            href={p.href}
            target={p.internal ? undefined : "_blank"}
            rel={p.internal ? undefined : "noopener noreferrer"}
            class={`block no-underline ${span}`}
            onclick={`trackEvent('click_eco_card', {destination: '${p.title}'})`}
          >
            <article class="group relative h-full flex flex-col justify-between p-6 md:p-8 bg-[var(--card)] border border-[var(--rule)] hover:border-[var(--ink)] transition-all overflow-hidden">
              <div class="flex items-start justify-between">
                <span class="text-4xl md:text-5xl">{p.emoji}</span>
                {p.tag && (
                  <span class="chip border-[var(--ember)] text-[var(--ember)]">
                    <span class="h-1.5 w-1.5 rounded-full bg-[var(--ember)]"></span> {p.tag}
                  </span>
                )}
              </div>

              <div class="mt-8">
                <h3 class={`font-display text-[var(--ink)] leading-tight ${p.featured ? "text-5xl md:text-6xl" : "text-3xl"}`}>
                  {p.title}
                </h3>
                <p class="mt-2 eyebrow">{p.sub}</p>
                <p class={`mt-4 text-[var(--ink-soft)] ${p.featured ? "text-base max-w-md" : "text-sm"}`}>
                  {p.desc}
                </p>

                <div class="mt-6 flex items-center justify-between gap-4 pt-4 border-t border-[var(--rule)]">
                  <span class="font-mono text-xs text-[var(--ink-soft)] truncate">{p.domain}</span>
                  <span class="inline-flex items-center gap-2 font-mono text-xs text-[var(--ink)] group-hover:text-[var(--ember)] transition-colors">
                    {p.cta} <span class="transition-transform group-hover:translate-x-1">→</span>
                  </span>
                </div>
              </div>

              <span
                aria-hidden="true"
                class="pointer-events-none absolute -bottom-10 -right-10 text-[180px] md:text-[260px] font-display leading-none text-[var(--ink)] opacity-[0.04] group-hover:opacity-[0.08] transition-opacity"
              >
                {String(idx + 1).padStart(2, "0")}
              </span>
            </article>
          </a>
        );
      })}
    </div>
  </section>

  {/* Stats Section */}
  <section class="rule-top border-b border-[var(--rule)] bg-[var(--paper-deep)] mt-10">
    <div class="container-edit py-12 grid grid-cols-2 md:grid-cols-4 gap-y-8">
      {STATS.map((s) => (
        <div class="text-center md:text-left md:border-l md:first:border-l-0 md:border-[var(--rule)] md:pl-6">
          <div class="font-display text-5xl md:text-6xl text-[var(--ink)]">{s.k}</div>
          <div class="eyebrow mt-2">{s.v}</div>
        </div>
      ))}
    </div>
  </section>

  {/* Build in Public Section */}
  <section class="container-edit pt-24 pb-12">
    <header class="flex flex-wrap items-end justify-between gap-6 mb-10">
      <div>
        <p class="eyebrow">BUILD IN PUBLIC · 最近在做什么</p>
        <h2 class="mt-3 font-display text-5xl md:text-6xl text-[var(--ink)]">
          公开构建是<br />我的<span class="italic text-[var(--ember)]">创作逻辑</span>。
        </h2>
      </div>
      <a href="/now/" class="font-mono text-sm text-[var(--ink)] hover:text-[var(--ember)] inline-flex items-center gap-2 no-underline">
        查看完整行动日志 →
      </a>
    </header>

    <ol class="relative border-l border-[var(--rule)] pl-8 space-y-10 list-none">
      {LOG.map((e) => (
        <li class="relative">
          <span class="absolute -left-[37px] top-1 grid place-items-center h-4 w-4 rounded-full bg-[var(--paper)] border-2 border-[var(--ember)]">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--ember)]"></span>
          </span>
          <div class="grid md:grid-cols-[160px_auto_1fr] gap-4 md:gap-8 items-baseline">
            <time class="font-mono text-xs text-[var(--ink-soft)]">{e.date}</time>
            <span class="chip self-start">{e.tag}</span>
            <div>
              <h3 class="font-display text-2xl md:text-3xl text-[var(--ink)]">{e.title}</h3>
              <p class="mt-2 text-[var(--ink-soft)] max-w-2xl">{e.body}</p>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  {/* Blog Teaser Section */}
  <section class="container-edit pt-24">
    <div class="grid md:grid-cols-12 gap-10 items-end rule-top pt-12">
      <div class="md:col-span-7">
        <p class="eyebrow">FROM THE BLOG · 博客近作</p>
        <h2 class="mt-3 font-display text-5xl md:text-6xl text-[var(--ink)] leading-tight">
          把每一次思考<br />都<span class="italic text-[var(--ember)]">沉淀</span>下来。
        </h2>
        <p class="mt-6 text-[var(--ink-soft)] max-w-lg">
          产品思考、独立开发实战、影视文化随笔。写作是我对外公开的最稳定杠杆。
        </p>
        <a
          href="/blog/"
          class="mt-8 inline-flex items-center gap-3 px-6 py-3.5 bg-[var(--ink)] text-[var(--paper)] text-sm tracking-wider uppercase font-mono hover:-translate-y-[2px] hover:-translate-x-[2px] hover:shadow-[4px_4px_0_0_var(--ember)] transition-all no-underline"
        >
          进入博客 →
        </a>
      </div>
      <ul class="md:col-span-5 space-y-5 list-none pl-0">
        {blogTeasers.map((b) => (
          <li class="group rule-top pt-5 first:border-0 first:pt-0">
            <a href={`/blog/${b.slug}/`} class="flex items-baseline justify-between gap-6 no-underline">
              <div>
                <p class="eyebrow">
                  {b.data.tags && b.data.tags[0] ? `${b.data.tags[0]} · ` : ''}
                  {b.data.pubDatetime.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
                </p>
                <h3 class="mt-2 font-display text-2xl text-[var(--ink)] group-hover:text-[var(--ember)] transition-colors">
                  {b.data.title}
                </h3>
              </div>
              <span class="font-mono text-[var(--ink-soft)] group-hover:text-[var(--ember)] group-hover:translate-x-1 inline-block transition-transform">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  @keyframes marquee {
    from { transform: translateX(0) }
    to { transform: translateX(-33.333%) }
  }
  .animate-\[marquee_38s_linear_infinite\] {
    animation: marquee 38s linear infinite;
  }
</style>
