---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '404 - 页面未找到 · 您访问的页面不存在或已被移动';
const description = '你要寻找的数字空间不存在，或者已经被移入更深的海底。您可以返回 Sanage 主港查看最新的博客文章，或者体验我们开发的脑力训练与测评工具。';
---

<BaseLayout title={title} description={description} ogImage="/images/og/home.png">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <section class="max-w-2xl mx-auto px-6 py-24 md:py-36 text-center min-h-[70vh] flex flex-col justify-center items-center">
    <div class="text-9xl font-bold text-[#b87333]/10 tracking-widest mb-2 animate-fade-in-up">404</div>
    <h1 class="text-3xl font-bold text-gray-900 mb-4 tracking-tight animate-fade-in-up delay-100">这个页面迷路了</h1>
    <p class="text-[14px] text-gray-500 mb-8 max-w-sm leading-relaxed animate-fade-in-up delay-200">你要寻找的数字空间不存在，或者已经被移入更深的海底。</p>
    <div class="flex flex-wrap gap-4 justify-center animate-fade-in-up delay-300">
      <a href="/" class="cta-primary">
        返回主港
      </a>
      <a href="/works/" class="btn-secondary">
        查看作品
      </a>
    </div>
  </section>
</BaseLayout>
