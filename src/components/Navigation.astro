---
const currentPath = Astro.url.pathname;

const NAV = [
  { url: '/works/', label: '作品', en: 'Works' },
  { url: '/now/', label: '现在', en: 'Now' },
  { url: '/about/', label: '关于', en: 'About' },
  { url: '/blog/', label: '博客', en: 'Blog' },
] as const;
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_oklab,var(--paper)_82%,transparent)] border-b border-[var(--rule)]">
  <div class="container-edit flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3 group no-underline">
      <img
        src="/sanage_logo.png"
        alt="三阿哥"
        class="h-9 w-auto object-contain transition-opacity duration-200 group-hover:opacity-80"
      />
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-[17px] text-[var(--ink)]">三阿哥又长高了吗</span>
        <span class="eyebrow text-[10px]">SANAGE · PERSONAL HUB</span>
      </span>
    </a>
    <nav class="flex items-center gap-1 sm:gap-2">
      {NAV.map((n) => {
        const isActive = currentPath === n.url || (n.url !== '/' && currentPath.startsWith(n.url));
        return (
          <a
            href={n.url}
            class={`group relative px-3 py-2 text-sm no-underline transition-colors ${
              isActive ? 'text-[var(--ink)] font-medium' : 'text-[var(--ink-soft)] hover:text-[var(--ink)]'
            }`}
            onclick={`trackEvent('click_nav', {destination: '${n.url}'})`}
          >
            <span class="font-display text-[15px]">{n.label}</span>
            <span class="ml-1 eyebrow text-[9px] hidden md:inline align-middle">{n.en}</span>
          </a>
        );
      })}
    </nav>
  </div>
</header>
